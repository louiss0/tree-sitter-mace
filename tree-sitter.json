{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mace",
      "camelcase": "Mace",
      "title": "Mace",
      "scope": "source.mace",
      "file-types": [
        "mace"
      ],
      "injection-regex": "^mace$",
      "class-name": "TreeSitterMace"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Mace language"
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}